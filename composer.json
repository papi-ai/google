{
    "name": "papi-ai/google",
    "description": "Google Gemini provider for PapiAI",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Marcello Duarte",
            "email": "marcello.duarte@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "papi-ai/papi-core": "^0.5",
        "ext-curl": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PapiAI\\Google\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PapiAI\\Google\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
